{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpportunityDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "is_recommended",
    "why_fit",
    "why_not_fit",
    "risks",
    "fit_score",
    "probability_to_win_score",
    "difficulty_score",
    "income_potential_score",
    "urgency_score",
    "skills_match_score",
    "decision_confidence_score"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "is_recommended": {
      "type": "boolean"
    },
    "why_fit": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "minItems": 0,
      "maxItems": 5
    },
    "why_not_fit": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "minItems": 0,
      "maxItems": 5
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      },
      "minItems": 0,
      "maxItems": 5
    },
    "fit_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "probability_to_win_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "difficulty_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "income_potential_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "urgency_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "skills_match_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "decision_confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  }
}
