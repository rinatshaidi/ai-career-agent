{
  "workflowName": "Collect Opportunities",
  "contractVersion": "v1",
  "implementedSources": {
    "rss": [
      {
        "name": "We Work Remotely RSS",
        "enabled": true,
        "type": "website",
        "configReference": "config/n8n/collect-opportunities.sources.json#implementedSources.rss.weworkremotely",
        "feedUrlEnv": "COLLECT_RSS_WWR_URL",
        "defaultFeedUrl": "https://weworkremotely.com/remote-jobs.rss",
        "defaultOpportunityType": "vacancy",
        "defaultRemoteType": "remote",
        "normalizer": "rss_generic_v1"
      },
      {
        "name": "Remote OK RSS",
        "enabled": true,
        "type": "website",
        "configReference": "config/n8n/collect-opportunities.sources.json#implementedSources.rss.remoteok",
        "feedUrlEnv": "COLLECT_RSS_REMOTEOK_URL",
        "defaultFeedUrl": "https://remoteok.com/remote-dev-jobs.rss",
        "defaultOpportunityType": "vacancy",
        "defaultRemoteType": "remote",
        "normalizer": "rss_generic_v1"
      }
    ],
    "headhunter": [
      {
        "name": "HeadHunter Automation Search",
        "enabled": true,
        "type": "job_board",
        "configReference": "config/n8n/collect-opportunities.sources.json#implementedSources.headhunter.automation",
        "endpoint": "https://api.hh.ru/vacancies",
        "requestUrlEnv": "COLLECT_HH_AUTOMATION_URL",
        "defaultRequestUrl": "https://api.hh.ru/vacancies?text=n8n%20OR%20automation%20OR%20integration%20OR%20workflow&per_page=20&order_by=publication_time",
        "defaultOpportunityType": "vacancy",
        "normalizer": "hh_vacancies_v1"
      },
      {
        "name": "HeadHunter OpenAI Search",
        "enabled": true,
        "type": "job_board",
        "configReference": "config/n8n/collect-opportunities.sources.json#implementedSources.headhunter.openai",
        "endpoint": "https://api.hh.ru/vacancies",
        "requestUrlEnv": "COLLECT_HH_OPENAI_URL",
        "defaultRequestUrl": "https://api.hh.ru/vacancies?text=openai%20OR%20llm%20OR%20ai%20automation%20OR%20telegram%20bot&per_page=20&order_by=publication_time",
        "defaultOpportunityType": "vacancy",
        "normalizer": "hh_vacancies_v1"
      }
    ],
    "telegramOfficialOnly": [
      {
        "name": "Telegram Official Channel Connector",
        "enabled": false,
        "type": "telegram",
        "configReference": "config/n8n/collect-opportunities.sources.json#implementedSources.telegramOfficialOnly.connector",
        "collectionMode": "bot_api_updates",
        "requiresManagedChannels": true,
        "requiresBotPresence": true,
        "requiresChannelPostUpdates": true,
        "notes": "Official Bot API only. Not for arbitrary public-channel scraping."
      }
    ]
  },
  "futureSourceBlueprints": [
    "Habr Career",
    "Remote OK",
    "Wellfound",
    "We Work Remotely",
    "Workzilla",
    "Kwork",
    "Freelance.ru",
    "FL.ru",
    "Upwork",
    "Company Career Pages"
  ]
}
