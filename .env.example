PROJECT_NAME=ai-career-agent
APP_ENV=local
TZ=Europe/Moscow
LOG_LEVEL=info

# Leave empty in Block 1.
# Enable local-infra only when you intentionally need an isolated local stack in a later block.
COMPOSE_PROFILES=

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_LOCAL_PORT=5433
POSTGRES_DB=ai_career_agent
POSTGRES_USER=ai_career_agent
POSTGRES_PASSWORD=change_me
POSTGRES_SSL_MODE=disable

N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_HOST=localhost
N8N_LOCAL_PORT=5679
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5679
WEBHOOK_URL=http://localhost:5679
N8N_ENCRYPTION_KEY=change_me
N8N_RUNNERS_ENABLED=true
N8N_POSTGRES_SCHEMA=public

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_BOT_NAME=Ri assistant

AI_DECISION_PROVIDER=openai
AI_DECISION_PROFILE_SLUG=
AI_DECISION_BATCH_SIZE=10
AI_DECISION_PROMPT_VERSION=block4-v1
AI_DECISION_MODEL=gpt-5.5
AI_DECISION_RETRY_DELAY_MINUTES=30
OPENAI_REQUEST_TIMEOUT_MS=60000

TELEGRAM_NOTIFICATION_PROFILE_SLUG=
TELEGRAM_NOTIFICATION_BATCH_SIZE=10
TELEGRAM_NOTIFICATION_RETRY_DELAY_MINUTES=30
TELEGRAM_NOTIFICATION_LOCK_TIMEOUT_MINUTES=30
TELEGRAM_REQUEST_TIMEOUT_MS=30000
TELEGRAM_INLINE_ACTIONS_ENABLED=false

COLLECT_RSS_WWR_URL=https://weworkremotely.com/remote-jobs.rss
COLLECT_RSS_REMOTEOK_URL=https://remoteok.com/remote-dev-jobs.rss
COLLECT_HH_AUTOMATION_URL=https://api.hh.ru/vacancies?text=n8n%20OR%20automation%20OR%20integration%20OR%20workflow&per_page=20&order_by=publication_time
COLLECT_HH_OPENAI_URL=https://api.hh.ru/vacancies?text=openai%20OR%20llm%20OR%20ai%20automation%20OR%20telegram%20bot&per_page=20&order_by=publication_time
COLLECT_TELEGRAM_ENABLED=false
