PROJECT_NAME=ai-career-agent
APP_ENV=local
TZ=Europe/Moscow
LOG_LEVEL=info

# Leave empty in Block 1.
# Enable local-infra only when you intentionally need an isolated local stack in a later block.
COMPOSE_PROFILES=

POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_LOCAL_PORT=5433
POSTGRES_DB=ai_career_agent
POSTGRES_USER=ai_career_agent
POSTGRES_PASSWORD=change_me
POSTGRES_SSL_MODE=disable

N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_HOST=localhost
N8N_LOCAL_PORT=5679
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5679
WEBHOOK_URL=http://localhost:5679
N8N_ENCRYPTION_KEY=change_me
N8N_RUNNERS_ENABLED=true
N8N_POSTGRES_SCHEMA=public

OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
