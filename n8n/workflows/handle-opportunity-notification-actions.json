            "index": 0
          }
        ]
      ]
    },
    "Parse Callback Action": {
      "main": [
        [
          {
            "node": "Callback Action Supported?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Callback Action Supported?": {
      "main": [
        [
          {
            "node": "Respond Unsupported Action",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Record Notification Action",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Record Notification Action": {
      "main": [
        [
          {
